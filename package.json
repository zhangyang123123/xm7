{
  "name": "cms-rest-api",
  "version": "1.0.0",
  "description": "Content Management System RESTful API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "ts-node src/db/migrate.ts"
  },
  "keywords": ["cms", "api", "rest", "express", "typescript"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
